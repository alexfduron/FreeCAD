def Crear_Huecos04_3D(LaT, AnT, AlT):
	
	### iniciar la orden PartDesign_Sketch
	global Boceto_Hueco4
	# Crear_Boceto(Titulo, Etiqueta = '', Objeto_X = False, Plano_X = '', Modelado_X = '', Mapa_X = 'FlatFace'):
	Boceto_Hueco4 = Crear_Boceto('Sketch_HuecoBase4_B001', 'B_HuecoBase4_B001', Cuerpo_B1, 'Face52', Tab8_Base3, 'InertialCS')
	
	Var_E = App.Units.Quantity(Variable_B1.Espesor).Value
	Var_R = 6.35 * (1 - math.cos(math.radians(45)))
	Var_L = ((AlT - 2 * Var_R) / math.cos(math.radians(45)) + 2 * 6.35 * math.cos(math.radians(45))) / 2
	
	# Crear_Ranura(Pt1, Boceto_X, Dist_X = False, Dist_Y = False, Angulo = 0, Guia = False, Grupo = '-'):
	Crear_Ranura(App.Vector(Var_L - 9.5 / 2 - 8, 0, 0), Boceto_Hueco4, 51.9, 9.5, math.radians(90), Grupo = 'R1')
	Boceto_Hueco4.setExpression('Constraints[32]', u'' + Variable_B1.Name + '.Ancho - 38.1 mm')
	Boceto_Hueco4.renameConstraint(32, u'' + Pieza_B1.Name + '_H4-R1_H')
	#Boceto_Hueco4.setExpression('Constraints[41]', u'((' + Variable_B1.Name + '.Alto - 2 * 6.35 * (1 - math.cos(math.radians(45)))) / math.cos(math.radians(45))) / 2 - ' + str(9.5 / 2 + 5) + ' mm')
	#Boceto_Hueco4.renameConstraint(41, u'' + Pieza_B1.Name + '_H4-R1_X')
	
	
	# Crear_Cuadrado(Pt1, Boceto_X, Tipo = 'Borde', Dist_X = False, Dist_Y = False, Radio = False, Angulo = 0, Guia = False, Grupo = '-'):
	Crear_Cuadrado(App.Vector(Var_L - 8 / 2, 0, 0), Boceto_Hueco4, 'Esquina', 32.85, 8, Angulo = math.radians(90), Grupo = 'C2')
	Boceto_Hueco4.setExpression('Constraints[50]', u'' + Variable_B1.Name + '.Ancho - 57.15 mm')
	Boceto_Hueco4.renameConstraint(50, u'' + Pieza_B1.Name + '_H4-C2_H')
	#Boceto_Hueco4.setExpression('Constraints[60]', u'((' + Variable_B1.Name + '.Alto - 2 * 6.35 * (1 - math.cos(math.radians(45)))) / math.cos(math.radians(45))) / 2 - ' + str(5 / 2) + ' mm')
	#Boceto_Hueco4.renameConstraint(60, u'' + Pieza_B1.Name + '_H4-C2_X')
	Boceto_Hueco4.AttachmentOffset = App.Placement(App.Vector(0, 0, 0), App.Rotation(App.Vector(0, 0, 1), 180))
	
	
	Doc.recompute()
	
	# Actualizar_Lista(Boceto_X):
	Actualizar_Lista(Boceto_Hueco4)
	Actualizar_Lista2(Boceto_Hueco4)
	
	global Hueco_Base4
	# Crear_Hueco(Titulo, Etiqueta = '', Objeto_X = False, Boceto_X = False):
	Hueco_Base4 = Crear_Hueco('Pocket_Base4_B001', 'Hueco_Base4_B001', Cuerpo_B1, Boceto_Hueco4)
	Hueco_Base4.SideType = 2
	Hueco_Base4.Type = 1
	
	Doc.recompute()
	
	
	
