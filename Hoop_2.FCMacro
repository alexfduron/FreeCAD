def Imprimir_Lista(Lista_X, Nom_Lista = 'Lista X'):
	
	# Aqui ajustamos las opciones de Pandas
	pd.set_option('display.max_columns', None)
	pd.set_option('display.max_rows', None)
	pd.set_option('display.width', 150)
	df = pd.DataFrame(Lista_X)
	
	# Aqui modificamos la apariencia de los datos
	df[1] = df[1].apply(lambda x : str(round(x, 3)).rstrip('0').rstrip('.'))
	df[2] = df[2].apply(lambda x : [ str(float(round(n, 3))).rstrip('0').rstrip('.').center(3) for n in x ])
	df[3] = df[3].apply(lambda x : [ str(float(round(n, 3))).rstrip('0').rstrip('.').center(3) for n in x ])
	df[4] = df[4].apply(lambda x : [ str(float(round(n, 3))).rstrip('0').rstrip('.').center(3) for n in x ])
	
	# Aqui agregamos los encabezados de las columnas
	newRow = pd.DataFrame(["ID objeto", "Longitud", "Punto inicio", "Punto final", "Centro curva", "Objeto", "Contenedor"]).T
	#df = df.set_axis(newRow.values[0], axis = "columns")
	df = pd.concat([df[:0], newRow.rename(columns=dict(zip(newRow.columns, df.columns))), df[0:]]).reset_index(drop = True)
	
	df = df.add_prefix("--", axis = "index")
	df = df.add_suffix("--", axis = "index")
	
	# Aqui mostramos la tabla en la consola de FreeCAD
	print(f'{Nom_Lista} = {len(Lista_X)}')
	print(df)
	
	print()
	
	
	
def Limpiar_Pantalla():
	
	mw = Gui.getMainWindow()
	
	rv = mw.findChild(QtGui.QTextEdit, "Report view")
	rv.clear()
	
	pc = mw.findChild(QtGui.QPlainTextEdit,"Python console")
	pc.onClearConsole()
	
	

#! Estas son las funciones para las partes que forman el Bastidor
def Crear_Hoop2(Largo_Total, Ancho_Total, Alto_Total):
	
	# aqui convertimos el texto a numero con las unidades por defecto en FreeCAD
	try:
		LaT = App.Units.Quantity(Largo_Total).Value
	except:
		raise TypeError(f'\n\n\t Mensaje = No es Numero \n\t Funcion = Crear_Bastidor \n\t (Largo_Total) = "{Largo_Total}"  ==>  {type(Largo_Total)}')
	
	try:
		AnT = App.Units.Quantity(Ancho_Total).Value
	except:
		raise TypeError(f'\n\n\t Mensaje = No es Numero \n\t Funcion = Crear_Bastidor \n\t (Ancho_Total) = "{Ancho_Total}"  ==>  {type(Ancho_Total)}')
	try:
		AlT = App.Units.Quantity(Alto_Total).Value
	except:
		raise TypeError(f'\n\n\t Mensaje = No es Numero \n\t Funcion = Crear_Bastidor \n\t (Alto_Total) = "{Alto_Total}"  ==>  {type(Alto_Total)}')
	
	# Limpiar_Pantalla():
	Limpiar_Pantalla()
	
	# Crear_Contenedor_3D(LaT, AnT, AlT):
	Crear_Contenedor_3D(LaT, AnT, AlT)
	
	# Crear_Bastidor_3D():
	Crear_Bastidor_3D()
	
	# Crear_Huecos01_3D():
	Crear_Huecos01_3D()
	
	# Crear_Huecos02_3D(LaT, AnT, AlT):
	Crear_Huecos02_3D(LaT, AnT, AlT)
	
	# Crear_Huecos03_3D(LaT, AnT, AlT):
	Crear_Huecos03_3D(LaT, AnT, AlT)
	
	# Crear_Doblez01():
	Crear_Doblez01()
	#Crear_Doblez02()
	#Crear_Doblez03()
	#Crear_Doblez04()
	#Crear_Doblez05()
	#Crear_Doblez06()
	#Crear_Doblez07()
	#Crear_Doblez08()
	
	# Crear_Huecos04_3D(LaT, AnT, AlT):
	#Crear_Huecos04_3D(LaT, AnT, AlT)
	
	# Crear_Huecos05_3D(LaT, AnT, AlT):
	#Crear_Huecos05_3D(LaT, AnT, AlT)
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
#! Crea el contenedor del objeto 3D
def Crear_Contenedor_3D(LaT, AnT, AlT):
	
	### iniciar la orden Std_Part
	global Pieza_B1
	Pieza_B1 = Crear_Pieza('Part_B001', 'Pieza_B001')
	
	global Variable_B1
	### iniciar la orden Var_Set
	Variable_B1 = Crear_Variables('VarSet_B001', 'Variables_B001', Pieza_B1, LaT, AnT, AlT)
	
	### iniciar la orden PartDesign_Body
	global Cuerpo_B1
	Cuerpo_B1 = Crear_Cuerpo('Body_B001', 'Cuerpo_B001', Pieza_B1)
	
	
	
def Crear_Pieza(Titulo, Etiqueta = ''):
	
	Crear_Doc()
	Pieza_X = Doc.addObject('App::Part', Titulo)
	Doc.Tip = Pieza_X
	if Etiqueta == '':
		Pieza_X.Label = Titulo
	else:
		Pieza_X.Label = Etiqueta
		
	Doc.recompute()
	return Pieza_X
	


def Crear_Doc():
	
	# Tomamos el archivo activo
	global Doc
	Doc = App.activeDocument()
	
	

def Crear_Variables(Titulo, Etiqueta, Objeto_X, LaT, AnT, AlT):
	
	# creamos las variables del objeto
	Var_X = Doc.addObject("App::VarSet", Titulo)
	Var_X.Label = Etiqueta
	Objeto_X.addObject(Var_X)
	
	Var_X.addProperty("App::PropertyLength", "Largo",     group="Grupo_Bastidor",    doc="Esta propiedad modifica el Largo del Bastidor")
	Var_X.Largo = LaT
	Var_X.addProperty("App::PropertyLength", "Ancho",     group="Grupo_Bastidor",    doc="Esta propiedad modifica el Ancho del Bastidor")
	Var_X.Ancho = AnT
	Var_X.addProperty("App::PropertyLength", "Alto",      group="Grupo_Bastidor",    doc="Esta propiedad modifica el Alto del Bastidor")
	Var_X.Alto = AlT
	Var_X.addProperty("App::PropertyLength", "Espesor",   group="Grupo_Bastidor",    doc="Esta propiedad modifica el grosor del Bastidor")
	Var_X.Espesor = "2 mm"
	
	Doc.recompute()
	return Var_X
	
	
	
def Crear_Cuerpo(Titulo, Etiqueta = '', Objeto_X = False):
	
	Cuerpo_X = Doc.addObject('PartDesign::Body', Titulo)
	if Etiqueta == '':
		Cuerpo_X.Label = Titulo
	else:
		Cuerpo_X.Label = Etiqueta
	if Objeto_X == False:
		Doc.Tip = Cuerpo_X
	else:
		Objeto_X.addObject(Cuerpo_X)
		
	Doc.recompute()
	return Cuerpo_X
	
	
	
def Crear_Boceto(Titulo, Etiqueta = '', Objeto_X = False, Plano_X = '', Modelado_X = '', Mapa_X = 'FlatFace'):
	
	Boceto_X = Doc.addObject('Sketcher::SketchObject', Titulo)
	Doc.Tip = Boceto_X
	if Etiqueta == '':
		Boceto_X.Label = Titulo
	else:
		Boceto_X.Label = Etiqueta
	Boceto_X.MapMode = Mapa_X
	if Modelado_X == '':
		if Plano_X == '':
			Plano_X = 'XY_Plane'
		if Objeto_X == False:
			Doc.Tip = Boceto_X
			Cuerpo_New = Crear_Cuerpo('New_Body', '', Pieza_C1)
			Cuerpo_New.addObject(Boceto_X)
			for k in Cuerpo_New.Origin.OriginFeatures:
				if k.Role == Plano_X:
					XY_Plano = k
			Boceto_X.AttachmentSupport = (Cuerpo_New.Origin, [XY_Plano.Name])
			del XY_Plano
		else:
			Objeto_X.addObject(Boceto_X)
			for k in Objeto_X.Origin.OriginFeatures:
				if k.Role == Plano_X:
					XY_Plano = k
			Boceto_X.AttachmentSupport = (Objeto_X.Origin, [XY_Plano.Name])
			del XY_Plano
	else:
		Objeto_X.addObject(Boceto_X)
		Boceto_X.AttachmentSupport = (Modelado_X, [Plano_X])
		
	Doc.recompute()
	return Boceto_X
	
	
	
def Crear_LineaRef(Titulo, Etiqueta = '', Objeto_X = False, Eje_X = '', Modelado_X = ''):
	
	LinRef_X = Doc.addObject('Part::DatumLine', Titulo)
	if Etiqueta == '':
		LinRef_X.Label = Titulo
	else:
		LinRef_X.Label = Etiqueta
	if Objeto_X == False:
		Doc.Tip = LinRef_X
	else:
		Objeto_X.addObject(LinRef_X)
	LinRef_X.MapMode = 'TwoPointLine'
	LinRef_X.AttachmentSupport = [(Modelado_X, Eje_X)]
	
	Doc.recompute()
	return LinRef_X
	
	
	
def Crear_PlanoRef(Titulo, Etiqueta = '', Objeto_X = False, Eje_X = '', Modelado_X = ''):
	
	PlanRef_X = Doc.addObject('Part::DatumPlane', Titulo)
	if Etiqueta == '':
		PlanRef_X.Label = Titulo
	else:
		PlanRef_X.Label = Etiqueta
	if Objeto_X == False:
		Doc.Tip = PlanRef_X
	else:
		Objeto_X.addObject(PlanRef_X)
	PlanRef_X.MapMode = 'NormalToEdge'
	PlanRef_X.AttachmentSupport = [(Modelado_X, Eje_X)]
	
	Doc.recompute()
	return PlanRef_X
	
	
	
#! Estos son las funciones para crear Objetos 2D
def Crear_Linea(Pt1, Pt2, Boceto_X, Guia = False):
	
	# aqui guardamos el ID de la linea.
	Lista_Obj.append(list(Boceto_X.addGeometry([Part.LineSegment(Pt1, Pt2)], Guia)))
	# aqui redondeamos los valores numericos de los vectores
	Pt1_Temp = [round(Pt1[0], 8), round(Pt1[1], 8), round(Pt1[2], 8)]
	Pt2_Temp = [round(Pt2[0], 8), round(Pt2[1], 8), round(Pt2[2], 8)]
	# aqui guardamos la magnitud de la linea.
	Pt3 = App.Vector(Pt2) - App.Vector(Pt1)
	Lista_Obj[-1].append(round(Pt3.Length, 8))
	# aqui guardamos el punto inicial.
	Lista_Obj[-1].append(Pt1_Temp)
	# aqui guardamos el punto final.
	Lista_Obj[-1].append(Pt2_Temp)
	# aqui guardamos el punto centro => N/A.
	Lista_Obj[-1].append([0.0, 0.0, 0.0])
	# aqui guardamos el nombre del objeto.
	Lista_Obj[-1].append('linea')
	# aqui guardamos el Boceto que contiene la linea.
	Lista_Obj[-1].append(Boceto_X.Label)
	


def Crear_Arco(Pt1, Eje, Radio, Boceto_X, Ang_Ini, Ang_Fin, Guia = False):
	
	# aqui guardamos el ID del arco.
	Lista_Obj.append(list(Boceto_X.addGeometry([Part.ArcOfCircle(Part.Circle(Pt1, Eje , Radio), Ang_Ini, Ang_Fin)], Guia)))
	# aqui creamos los puntos de los extremos del arco con los valores numericos redondeados
	Pt1_Temp = App.Vector(round(Pt1.x + Radio * math.cos(Ang_Ini), 8), round(Pt1.y + Radio * math.sin(Ang_Ini), 8), round(Pt1.z, 8))
	Pt2_Temp = App.Vector(round(Pt1.x + Radio * math.cos(Ang_Fin), 8), round(Pt1.y + Radio * math.sin(Ang_Fin), 8), round(Pt1.z, 8))
	Eje_Temp = App.Vector(round(Pt1.x, 8), round(Pt1.y, 8), round(Pt1.z, 8))
	# aqui guardamos el radio.
	Lista_Obj[-1].append(round(Radio, 8))
	# aqui guardamos el punto inicial.
	Lista_Obj[-1].append(list(Pt1_Temp))
	# aqui guardamos el punto final.
	Lista_Obj[-1].append(list(Pt2_Temp))
	# aqui guardamos el punto central del arco.
	Lista_Obj[-1].append(list(Eje_Temp))
	# aqui guardamos el nombre del objeto.
	Lista_Obj[-1].append('arco')
	# aqui guardamos el Boceto que contiene al arco.
	Lista_Obj[-1].append(Boceto_X.Label)
	


def Crear_Circulo(Pt1, Eje, Radio, Boceto_X, Guia = False):
	
	# aqui guardamos el ID del circulo.
	Lista_Obj.append(list(Boceto_X.addGeometry([Part.Circle(Pt1, Eje, Radio)], Guia)))
	# aqui creamos el punto centro del circulo con los valores numericos redondeados
	Eje_Temp = App.Vector(round(Pt1.x, 8), round(Pt1.y, 8), round(Pt1.z, 8))
	# aqui guardamos el radio.
	Lista_Obj[-1].append(round(Radio, 8))
	# aqui guardamos el punto inicial => N/A.
	Lista_Obj[-1].append([0, 0, 0])
	# aqui guardamos el punto final => N/A.
	Lista_Obj[-1].append([0, 0, 0])
	# aqui guardamos el punto central del circulo.
	Lista_Obj[-1].append(list(Eje_Temp))
	# aqui guardamos el nombre del objeto.
	Lista_Obj[-1].append('circulo')
	# aqui guardamos el Boceto que contiene al circulo.
	Lista_Obj[-1].append(Boceto_X.Label)
	
	
	
def Crear_Punto(Pt1, Boceto_X, Guia = False):
	
	# aqui guardamos el ID del punto.
	Lista_Obj.append(list(Boceto_X.addGeometry([Part.Point(Pt1)], Guia)))
	# aqui redondeamos los valores numericos de los vectores
	Pt1_Temp = [round(Pt1[0], 8), round(Pt1[1], 8), round(Pt1[2], 8)]
	# aqui guardamos la magnitud del punto => N/A.
	Lista_Obj[-1].append(0)
	# aqui guardamos el punto inicial.
	Lista_Obj[-1].append(Pt1_Temp)
	# aqui guardamos el punto final => N/A.
	Lista_Obj[-1].append([0.0, 0.0, 0.0])
	# aqui guardamos el punto centro => N/A.
	Lista_Obj[-1].append([0.0, 0.0, 0.0])
	# aqui guardamos el nombre del objeto.
	Lista_Obj[-1].append('punto')
	# aqui guardamos el Boceto que contiene el punto.
	Lista_Obj[-1].append(Boceto_X.Label)
	
	
	
def Crear_Cuadrado(Pt1, Boceto_X, Tipo = 'Borde', Dist_X = False, Dist_Y = False, Radio = False, Angulo = 0, Guia = False):
	
	# Tipos:
	#	Esquina
	#	Borde
	
	# validar entrada
	if Dist_X == False:
		Dist_X = 100
	else:
		Dist_X = Dist_X / 2
	if Dist_Y == False:
		Dist_Y = 100
	else:
		Dist_Y = Dist_Y / 2
	if Radio == False:
		Radio = 10
	
	lastID = len(Boceto_X.Geometry)
	
	# creamos la lista de puntos por cada linea
	geoList = []
	if Tipo == 'Borde':
		# [Punto inicial, Punto final]
		geoList.append([App.Vector(-Dist_X + Pt1.x,          Dist_Y - Radio + Pt1.y, Pt1.z), App.Vector(-Dist_X + Pt1.x,         -Dist_Y + Radio + Pt1.y, Pt1.z)])		#Object[B0]
		geoList.append([App.Vector(-Dist_X + Radio + Pt1.x, -Dist_Y + Pt1.y,         Pt1.z), App.Vector( Dist_X - Radio + Pt1.x, -Dist_Y + Pt1.y,         Pt1.z)])		#Object[B1]
		geoList.append([App.Vector( Dist_X + Pt1.x,         -Dist_Y + Radio + Pt1.y, Pt1.z), App.Vector( Dist_X + Pt1.x,          Dist_Y - Radio + Pt1.y, Pt1.z)])		#Object[B2]
		geoList.append([App.Vector( Dist_X - Radio +Pt1.x,   Dist_Y + Pt1.y,         Pt1.z), App.Vector(-Dist_X + Radio + Pt1.x,  Dist_Y + Pt1.y,         Pt1.z)])		#Object[B3]
	
	if Tipo == 'Esquina':
		# [Punto inicial, Punto final]
		geoList.append([App.Vector(-Dist_X + Pt1.x,  Dist_Y + Pt1.y, Pt1.z), App.Vector(-Dist_X + Pt1.x, -Dist_Y + Pt1.y, Pt1.z)])		#Object[E0]
		geoList.append([App.Vector(-Dist_X + Pt1.x, -Dist_Y + Pt1.y, Pt1.z), App.Vector( Dist_X + Pt1.x, -Dist_Y + Pt1.y, Pt1.z)])		#Object[E1]
		geoList.append([App.Vector( Dist_X + Pt1.x, -Dist_Y + Pt1.y, Pt1.z), App.Vector( Dist_X + Pt1.x,  Dist_Y + Pt1.y, Pt1.z)])		#Object[E2]
		geoList.append([App.Vector( Dist_X + Pt1.x,  Dist_Y + Pt1.y, Pt1.z), App.Vector(-Dist_X + Pt1.x,  Dist_Y + Pt1.y, Pt1.z)])		#Object[E3]
	
	for NewLinea in geoList:
		# Crear_Linea(Pt1, Pt2, Boceto_X, Guia = False):
		Crear_Linea(NewLinea[0], NewLinea[1], Boceto_X, Guia)
	
	del geoList
	
	if Tipo == 'Borde':
		# creamos la lista de puntos por cada arco
		geoList = []
		# [centro curva, Eje, Radio, Angulo inicial, Angulo final]
		geoList.append([App.Vector(-Dist_X + Radio + Pt1.x,  Dist_Y - Radio + Pt1.y, Pt1.z), App.Vector(0, 0, 1), Radio, math.radians( 90), math.radians(180)])	#Object[B4]
		geoList.append([App.Vector(-Dist_X + Radio + Pt1.x, -Dist_Y + Radio + Pt1.y, Pt1.z), App.Vector(0, 0, 1), Radio, math.radians(180), math.radians(270)])	#Object[B5]
		geoList.append([App.Vector( Dist_X - Radio + Pt1.x, -Dist_Y + Radio + Pt1.y, Pt1.z), App.Vector(0, 0, 1), Radio, math.radians(270), math.radians(360)])	#Object[B6]
		geoList.append([App.Vector( Dist_X - Radio + Pt1.x,  Dist_Y - Radio + Pt1.y, Pt1.z), App.Vector(0, 0, 1), Radio, math.radians(  0), math.radians( 90)])	#Object[B7]
		
		for NewArco in geoList:
			# Crear_Arco(Pt1, Eje, Radio, Boceto_X, Ang_Ini, Ang_Fin, Guia = False):
			Crear_Arco(NewArco[0], NewArco[1], NewArco[2], Boceto_X, NewArco[3], NewArco[4], Guia)
		
		del geoList
	
	# creamos la lista de puntos auxiliares
	geoList = []
	if Tipo == 'Borde':
		# [Punto inicial]
		geoList.append([App.Vector(-Dist_X + Pt1.x,  Dist_Y + Pt1.y, Pt1.z)])		#Object[B8]
		geoList.append([App.Vector( Dist_X + Pt1.x,  Dist_Y + Pt1.y, Pt1.z)])		#Object[B9]
		geoList.append([App.Vector( Dist_X + Pt1.x, -Dist_Y + Pt1.y, Pt1.z)])		#Object[B10]
		geoList.append([App.Vector(-Dist_X + Pt1.x, -Dist_Y + Pt1.y, Pt1.z)])		#Object[B11]
	# [Punto inicial]
	geoList.append([App.Vector(Pt1.x, Pt1.y, Pt1.z)])							#Object[B12,E4]
	
	for NewPunto in geoList:
		# Crear_Punto(Pt1, Boceto_X, Guia = False):
		Crear_Punto(NewPunto[0], Boceto_X, True)
		
	del geoList
	
	# creamos la lista de puntos por cada linea auxiliar
	geoList = []
	# [Punto inicial, Punto final]
	geoList.append([App.Vector(Pt1.x, Pt1.y, Pt1.z), App.Vector(Radio + Pt1.x, Pt1.y, Pt1.z)])		#Object[B13,E5]
	geoList.append([App.Vector(Pt1.x, Pt1.y, Pt1.z), App.Vector(Radio + Pt1.x, Pt1.y, Pt1.z)])		#Object[B14,E6]
	
	for NewLinea in geoList:
		# Crear_Linea(Pt1, Pt2, Boceto_X, Guia = False):
		Crear_Linea(NewLinea[0], NewLinea[1], Boceto_X, True)
	
	del geoList
	
	# creamos la lista de restricciones
	constraintList = []
	if Tipo == 'Borde':
		constraintList.append(Sketcher.Constraint('Tangent',       lastID + 0,1,  lastID + 4,2))					#Constraints[0]
		constraintList.append(Sketcher.Constraint('Tangent',       lastID + 0,2,  lastID + 5,1))					#Constraints[1]
		constraintList.append(Sketcher.Constraint('Tangent',       lastID + 1,1,  lastID + 5,2))					#Constraints[2]
		constraintList.append(Sketcher.Constraint('Tangent',       lastID + 1,2,  lastID + 6,1))					#Constraints[3]
		constraintList.append(Sketcher.Constraint('Tangent',       lastID + 2,1,  lastID + 6,2))					#Constraints[4]
		constraintList.append(Sketcher.Constraint('Tangent',       lastID + 2,2,  lastID + 7,1))					#Constraints[5]
		constraintList.append(Sketcher.Constraint('Tangent',       lastID + 3,1,  lastID + 7,2))					#Constraints[6]
		constraintList.append(Sketcher.Constraint('Tangent',       lastID + 3,2,  lastID + 4,1))					#Constraints[7]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 0,    lastID + 1))					#Constraints[8]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 1,    lastID + 2))					#Constraints[9]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 2,    lastID + 3))					#Constraints[10]
		constraintList.append(Sketcher.Constraint('Equal',         lastID + 4,    lastID + 5))					#Constraints[11]
		constraintList.append(Sketcher.Constraint('Equal',         lastID + 5,    lastID + 6))					#Constraints[12]
		constraintList.append(Sketcher.Constraint('Equal',         lastID + 6,    lastID + 7))					#Constraints[13]
		constraintList.append(Sketcher.Constraint('PointOnObject', lastID + 8,1,  lastID + 0))					#Constraints[14]
		constraintList.append(Sketcher.Constraint('PointOnObject', lastID + 8,1,  lastID + 3))					#Constraints[15]
		constraintList.append(Sketcher.Constraint('PointOnObject', lastID + 9,1,  lastID + 2))					#Constraints[16]
		constraintList.append(Sketcher.Constraint('PointOnObject', lastID + 9,1,  lastID + 3))					#Constraints[17]
		constraintList.append(Sketcher.Constraint('PointOnObject', lastID + 10,1, lastID + 1))					#Constraints[18]
		constraintList.append(Sketcher.Constraint('PointOnObject', lastID + 10,1, lastID + 2))					#Constraints[19]
		constraintList.append(Sketcher.Constraint('PointOnObject', lastID + 11,1, lastID + 0))					#Constraints[20]
		constraintList.append(Sketcher.Constraint('PointOnObject', lastID + 11,1, lastID + 1))					#Constraints[21]
		constraintList.append(Sketcher.Constraint('Radius',        lastID + 5,    Radio)) 						#Constraints[22]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 8,1,  lastID + 9,1,  2*Dist_X))		#Constraints[23]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 9,1,  lastID + 10,1, 2*Dist_Y))		#Constraints[24]
		constraintList.append(Sketcher.Constraint('Symmetric',     lastID + 8,1,  lastID + 10,1, lastID + 12,1))	#Constraints[25]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 13,1, lastID + 12,1))					#Constraints[26]
		constraintList.append(Sketcher.Constraint('Parallel',      lastID + 13,   lastID + 3))					#Constraints[27]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 13,1, lastID + 13,2, Radio))			#Constraints[28]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 14,1, lastID + 12,1))					#Constraints[29]
		constraintList.append(Sketcher.Constraint('Horizontal',    lastID + 14))									#Constraints[30]
		constraintList.append(Sketcher.Constraint('DistanceX',     lastID + 14,1, lastID + 14,2, Radio))			#Constraints[31]
		constraintList.append(Sketcher.Constraint('Angle',         lastID + 14,1, lastID + 13,1,  Angulo))		#Constraints[32]
		constraintList.append(Sketcher.Constraint('DistanceX',     lastID + 12,1, Pt1.x))							#Constraints[33]
		constraintList.append(Sketcher.Constraint('DistanceY',     lastID + 12,1, Pt1.y))							#Constraints[34]
	
	if Tipo == 'Esquina':
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 0,2, lastID + 1,1))					#Constraints[0]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 1,2, lastID + 2,1))					#Constraints[1]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 2,2, lastID + 3,1))					#Constraints[2]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 3,2, lastID + 0,1))					#Constraints[3]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 0,   lastID + 1))						#Constraints[4]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 1,   lastID + 2))						#Constraints[5]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 2,   lastID + 3))						#Constraints[6]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 3,1, lastID + 3,2, 2*Dist_X))			#Constraints[7]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 0,1, lastID + 0,2, 2*Dist_Y))			#Constraints[8]
		constraintList.append(Sketcher.Constraint('Symmetric',     lastID + 0,1, lastID + 1,2, lastID + 4,1))		#Constraints[9]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 5,1, lastID + 4,1))					#Constraints[10]
		constraintList.append(Sketcher.Constraint('Parallel',      lastID + 5,   lastID + 3))						#Constraints[11]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 5,1, lastID + 5,2, 10))				#Constraints[12]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 6,1, lastID + 4,1))					#Constraints[13]
		constraintList.append(Sketcher.Constraint('Horizontal',    lastID + 6))									#Constraints[14]
		constraintList.append(Sketcher.Constraint('DistanceX',     lastID + 6,1, lastID + 6,2, 10))				#Constraints[15]
		constraintList.append(Sketcher.Constraint('Angle',         lastID + 6,1, lastID + 5,1, Angulo))			#Constraints[16]
		constraintList.append(Sketcher.Constraint('DistanceX',     lastID + 4,1, Pt1.x))							#Constraints[17]
		constraintList.append(Sketcher.Constraint('DistanceY',     lastID + 4,1, Pt1.y))							#Constraints[18]
		
	Boceto_X.addConstraint(constraintList)
	
	del constraintList
	
	Doc.recompute()
	
	
	
def Crear_Ranura(Pt1, Boceto_X, Dist_X = False, Dist_Y = False, Angulo = 0, Guia = False):
	
	# validar entrada
	if Dist_X == False:
		Dist_X = 100
	else:
		Dist_X = Dist_X / 2
	if Dist_Y == False:
		Dist_Y = 50
	else:
		Dist_Y = Dist_Y / 2
	Radio = Dist_Y
	
	lastID = len(Boceto_X.Geometry)
	
	# creamos la lista de puntos por cada arco
	geoList = []
	# [centro curva, Eje, Radio, Angulo inicial, Angulo final]
	geoList.append([App.Vector(-Dist_X + Radio + Pt1.x, Pt1.y, Pt1.z), App.Vector(0, 0, 1), Radio, math.radians( 90), math.radians(180)])	#Object[0]
	geoList.append([App.Vector(-Dist_X + Radio + Pt1.x, Pt1.y, Pt1.z), App.Vector(0, 0, 1), Radio, math.radians(180), math.radians(270)])	#Object[1]
	geoList.append([App.Vector( Dist_X - Radio + Pt1.x, Pt1.y, Pt1.z), App.Vector(0, 0, 1), Radio, math.radians(270), math.radians(360)])	#Object[2]
	geoList.append([App.Vector( Dist_X - Radio + Pt1.x, Pt1.y, Pt1.z), App.Vector(0, 0, 1), Radio, math.radians(  0), math.radians( 90)])	#Object[3]
	
	for NewArco in geoList:
		# Crear_Arco(Pt1, Eje, Radio, Boceto_X, Ang_Ini, Ang_Fin, Guia = False):
		Crear_Arco(NewArco[0], NewArco[1], NewArco[2], Boceto_X, NewArco[3], NewArco[4], Guia)
	
	del geoList
	
	# creamos la lista de puntos por cada linea
	geoList = []
	# [Punto inicial, Punto final]
	geoList.append([App.Vector(-Dist_X + Radio + Pt1.x,  Dist_Y + Pt1.y, Pt1.z), App.Vector(Dist_X - Radio + Pt1.x,  Dist_Y + Pt1.y, Pt1.z)])		#Object[4]
	geoList.append([App.Vector(-Dist_X + Radio + Pt1.x, -Dist_Y + Pt1.y, Pt1.z), App.Vector(Dist_X - Radio + Pt1.x, -Dist_Y + Pt1.y, Pt1.z)])		#Object[5]
	
	for NewLinea in geoList:
		# Crear_Linea(Pt1, Pt2, Boceto_X, Guia = False):
		Crear_Linea(NewLinea[0], NewLinea[1], Boceto_X, Guia)
	
	del geoList
	
	# creamos la lista de puntos por cada linea auxiliar
	geoList = []
	# [Punto inicial, Punto final]
	geoList.append([App.Vector(-Dist_X + Pt1.x, Pt1.y, Pt1.z),         App.Vector(-Dist_X + Radio + Pt1.x, Pt1.y, Pt1.z)])				#Object[6]
	geoList.append([App.Vector(-Dist_X + Radio + Pt1.x, Pt1.y, Pt1.z), App.Vector(-Dist_X + Radio + Pt1.x, Dist_Y + Pt1.y, Pt1.z)])		#Object[7]
	geoList.append([App.Vector( Dist_X + Pt1.x, Pt1.y, Pt1.z),         App.Vector( Dist_X - Radio + Pt1.x, Pt1.y, Pt1.z)])				#Object[8]
	geoList.append([App.Vector( Dist_X - Radio + Pt1.x, Pt1.y, Pt1.z), App.Vector( Dist_X - Radio + Pt1.x, -Dist_Y + Pt1.y, Pt1.z)])		#Object[9]
	geoList.append([App.Vector(-Dist_X + Pt1.x,  Dist_Y + Pt1.y, Pt1.z), App.Vector(-Dist_X + Radio + Pt1.x,  Dist_Y + Pt1.y, Pt1.z)])	#Object[10]
	geoList.append([App.Vector( Dist_X + Pt1.x,  Dist_Y + Pt1.y, Pt1.z), App.Vector( Dist_X - Radio + Pt1.x,  Dist_Y + Pt1.y, Pt1.z)])	#Object[11]
	geoList.append([App.Vector(-Dist_X + Pt1.x, -Dist_Y + Pt1.y, Pt1.z), App.Vector(-Dist_X + Radio + Pt1.x, -Dist_Y + Pt1.y, Pt1.z)])	#Object[12]
	geoList.append([App.Vector( Dist_X + Pt1.x, -Dist_Y + Pt1.y, Pt1.z), App.Vector( Dist_X - Radio + Pt1.x, -Dist_Y + Pt1.y, Pt1.z)])	#Object[13]
	
	geoList.append([App.Vector( Pt1.x, Pt1.y, Pt1.z), App.Vector( Radio + Pt1.x, Pt1.y, Pt1.z)])			#Object[14]
	geoList.append([App.Vector( Pt1.x, Pt1.y, Pt1.z), App.Vector( Radio + Pt1.x, Pt1.y, Pt1.z)])			#Object[15]
	
	for NewLinea in geoList:
		# Crear_Linea(Pt1, Pt2, Boceto_X, Guia = False):
		Crear_Linea(NewLinea[0], NewLinea[1], Boceto_X, True)
	
	del geoList
	
	# creamos la lista de puntos auxiliares
	geoList = []
	# [Punto inicial]
	geoList.append([App.Vector(Pt1.x, Pt1.y, Pt1.z)])			#Object[16]
	
	for NewPunto in geoList:
		# Crear_Punto(Pt1, Boceto_X, Guia = False):
		Crear_Punto(NewPunto[0], Boceto_X, True)
		
	del geoList
	
	# creamos la lista de restricciones
	constraintList = []
	constraintList.append(Sketcher.Constraint('Tangent',       lastID + 0,1,  lastID + 4,1))						#Constraints[0]
	constraintList.append(Sketcher.Constraint('Tangent',       lastID + 0,2,  lastID + 1,1))						#Constraints[1]
	constraintList.append(Sketcher.Constraint('Tangent',       lastID + 1,2,  lastID + 5,1))						#Constraints[2]
	constraintList.append(Sketcher.Constraint('Tangent',       lastID + 2,1,  lastID + 5,2))						#Constraints[3]
	constraintList.append(Sketcher.Constraint('Tangent',       lastID + 2,2,  lastID + 3,1))						#Constraints[4]
	constraintList.append(Sketcher.Constraint('Tangent',       lastID + 3,2,  lastID + 4,2))						#Constraints[5]
	constraintList.append(Sketcher.Constraint('Equal',         lastID + 0,    lastID + 1))						#Constraints[6]
	constraintList.append(Sketcher.Constraint('Equal',         lastID + 1,    lastID + 2))						#Constraints[7]
	constraintList.append(Sketcher.Constraint('Equal',         lastID + 2,    lastID + 3))						#Constraints[8]
	constraintList.append(Sketcher.Constraint('Equal',         lastID + 6,    lastID + 10))						#Constraints[9]
	constraintList.append(Sketcher.Constraint('Equal',         lastID + 8,    lastID + 11))						#Constraints[10]
	constraintList.append(Sketcher.Constraint('Equal',         lastID + 6,    lastID + 12))						#Constraints[11]
	constraintList.append(Sketcher.Constraint('Equal',         lastID + 8,    lastID + 13))						#Constraints[12]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 0,2,  lastID + 6,1))						#Constraints[13]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 6,2,  lastID + 0,3))						#Constraints[14]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 0,1,  lastID + 7,2))						#Constraints[15]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 7,1,  lastID + 0,3))						#Constraints[16]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 2,2,  lastID + 8,1))						#Constraints[17]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 8,2,  lastID + 2,3))						#Constraints[18]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 2,1,  lastID + 9,2))						#Constraints[19]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 9,1,  lastID + 2,3))						#Constraints[20]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 10,2, lastID + 4,1))						#Constraints[21]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 11,2, lastID + 4,2))						#Constraints[22]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 12,2, lastID + 5,1))						#Constraints[23]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 13,2, lastID + 5,2))						#Constraints[24]
	constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 7,    lastID + 6))						#Constraints[25]
	constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 9,    lastID + 8))						#Constraints[26]
	constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 10,   lastID + 7))						#Constraints[27]
	constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 11,   lastID + 9))						#Constraints[28]
	constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 12,   lastID + 7))						#Constraints[29]
	constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 13,   lastID + 9))						#Constraints[30]
	constraintList.append(Sketcher.Constraint('Symmetric',     lastID + 1,3,  lastID + 3,3,  lastID + 16,1))		#Constraints[31]
	constraintList.append(Sketcher.Constraint('Distance',      lastID + 10,1, lastID + 11,1, 2*Dist_X))			#Constraints[32]
	constraintList.append(Sketcher.Constraint('Distance',      lastID + 10,1, lastID + 12,1, 2*Dist_Y))			#Constraints[33]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 16,1, lastID + 14,1))						#Constraints[34]
	constraintList.append(Sketcher.Constraint('Horizontal',    lastID + 14))										#Constraints[35]
	constraintList.append(Sketcher.Constraint('DistanceX',     lastID + 14,1, lastID + 14,2, Radio))				#Constraints[36]
	constraintList.append(Sketcher.Constraint('Coincident',    lastID + 16,1, lastID + 15,1))						#Constraints[37]
	constraintList.append(Sketcher.Constraint('Parallel',      lastID + 15,   lastID + 4))						#Constraints[38]
	constraintList.append(Sketcher.Constraint('Distance',      lastID + 15,1, lastID + 15,2, Radio))				#Constraints[39]
	constraintList.append(Sketcher.Constraint('Angle',         lastID + 14,1, lastID + 15,1, Angulo))				#Constraints[40]
	constraintList.append(Sketcher.Constraint('DistanceX',     lastID + 16,1, Pt1.x))								#Constraints[41]
	constraintList.append(Sketcher.Constraint('DistanceY',     lastID + 16,1, Pt1.y))								#Constraints[42]
	
	Boceto_X.addConstraint(constraintList)
	
	del constraintList
	
	Doc.recompute
	
	
	
def Crear_Semicirculo(Pt1, Boceto_X, Dist_X = False, Dist_Y = False, Tipo = 'B', Angulo = 0, Guia = False):
	
	# Tipos:
	#	A => Semicirculo
	#	B => Semicirculo + Cuadrado
	
	# validar entrada
	if Dist_X == False:
		Dist_X = 100
	else:
		Dist_X = Dist_X / 2
	if Dist_Y == False:
		Dist_Y = 200
	if Dist_Y - Dist_X > 0:
		Largo = Dist_Y - Dist_X
	else:
		Tipo = 'A'
	Radio = Dist_X
	
	lastID = len(Boceto_X.Geometry)
	
	# creamos la lista de puntos por cada arco
	geoList = []
	# [centro curva, Eje, Radio, Angulo inicial, Angulo final]
	geoList.append([App.Vector(Pt1.x, Pt1.y, Pt1.z), App.Vector(0, 0, 1), Radio, math.radians( 0), math.radians( 90)])	#Object[A0,B0]
	geoList.append([App.Vector(Pt1.x, Pt1.y, Pt1.z), App.Vector(0, 0, 1), Radio, math.radians(90), math.radians(180)])	#Object[A1,B0]
	
	for NewArco in geoList:
		# Crear_Arco(Pt1, Eje, Radio, Boceto_X, Ang_Ini, Ang_Fin, Guia = False):
		Crear_Arco(NewArco[0], NewArco[1], NewArco[2], Boceto_X, NewArco[3], NewArco[4], Guia)
	
	del geoList
	
	# creamos la lista de puntos por cada linea
	geoList = []
	if Tipo == 'A':
		# [Punto inicial, Punto final]
		geoList.append([App.Vector(-Dist_X + Pt1.x, Pt1.y, Pt1.z), App.Vector(Dist_X + Pt1.x, Pt1.y, Pt1.z)])				#Object[A2]
	if Tipo == 'B':
		# [Punto inicial, Punto final]
		geoList.append([App.Vector(-Dist_X + Pt1.x, -Largo + Pt1.y, Pt1.z), App.Vector( Dist_X + Pt1.x, -Largo + Pt1.y, Pt1.z)])	#Object[B2]
		geoList.append([App.Vector(-Dist_X + Pt1.x,          Pt1.y, Pt1.z), App.Vector(-Dist_X + Pt1.x, -Largo + Pt1.y, Pt1.z)])	#Object[B3]
		geoList.append([App.Vector( Dist_X + Pt1.x,          Pt1.y, Pt1.z), App.Vector( Dist_X + Pt1.x, -Largo + Pt1.y, Pt1.z)])	#Object[B4]
		
	for NewLinea in geoList:
		# Crear_Linea(Pt1, Pt2, Boceto_X, Guia = False):
		Crear_Linea(NewLinea[0], NewLinea[1], Boceto_X, Guia)
	
	del geoList
	
	# creamos la lista de puntos por cada linea auxiliar
	geoList = []
	# [Punto inicial, Punto final]
	geoList.append([App.Vector(-Dist_X + Pt1.x, Pt1.y, Pt1.z), App.Vector(-Dist_X + Pt1.x, Radio + Pt1.y, Pt1.z)])		#Object[A3,B5]
	geoList.append([App.Vector(          Pt1.x, Pt1.y, Pt1.z), App.Vector(          Pt1.x, Radio + Pt1.y, Pt1.z)])		#Object[A4,B6]
	geoList.append([App.Vector( Dist_X + Pt1.x, Pt1.y, Pt1.z), App.Vector( Dist_X + Pt1.x, Radio + Pt1.y, Pt1.z)])		#Object[A5,B7]
	
	geoList.append([App.Vector( Pt1.x, Pt1.y, Pt1.z),          App.Vector(Radio + Pt1.x, Pt1.y, Pt1.z)])					#Object[A6.,B8.]
	geoList.append([App.Vector( Pt1.x, Pt1.y, Pt1.z),          App.Vector(Radio + Pt1.x, Pt1.y, Pt1.z)])					#Object[A7.,B9.]
	if Tipo == 'B':
		# [Punto inicial, Punto final]
		geoList.append([App.Vector(-Dist_X + Pt1.x, Pt1.y, Pt1.z), App.Vector(Dist_X + Pt1.x, Pt1.y, Pt1.z)])				#Object[B10]
		
	for NewLinea in geoList:
		# Crear_Linea(Pt1, Pt2, Boceto_X, Guia = False):
		Crear_Linea(NewLinea[0], NewLinea[1], Boceto_X, True)
	
	del geoList
	
	# creamos la lista de puntos auxiliares
	geoList = []
	# [Punto inicial]
	geoList.append([App.Vector(Pt1.x, Radio / 2 + Pt1.y, Pt1.z)])														#Object[A8,B11]
	
	for NewPunto in geoList:
		# Crear_Punto(Pt1, Boceto_X, Guia = False):
		Crear_Punto(NewPunto[0], Boceto_X, True)
		
	del geoList
	
	# creamos la lista de restricciones
	constraintList = []
	constraintList.append(Sketcher.Constraint('Coincident',        lastID + 1,3, lastID + 0,3))					#Constraints[A0,B0]
	constraintList.append(Sketcher.Constraint('Coincident',        lastID + 1,1, lastID + 0,2))					#Constraints[A1,B1]
	if Tipo == 'A':
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 2,1, lastID + 1,2))					#Constraints[A2]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 2,2, lastID + 0,1))					#Constraints[A3]
		constraintList.append(Sketcher.Constraint('PointOnObject', lastID + 0,3, lastID + 2))						#Constraints[A4]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 4,1, lastID + 0,3))					#Constraints[A5]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 4,2, lastID + 0,2))					#Constraints[A6]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 3,1, lastID + 1,2))					#Constraints[A7]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 5,1, lastID + 0,1))					#Constraints[A8]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 4,   lastID + 2))						#Constraints[A9]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 3,   lastID + 2))						#Constraints[A10]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 5,   lastID + 2))						#Constraints[A11]
		constraintList.append(Sketcher.Constraint('Equal',         lastID + 4,   lastID + 5))						#Constraints[A12]
		constraintList.append(Sketcher.Constraint('Equal',         lastID + 4,   lastID + 3))						#Constraints[A13]
		constraintList.append(Sketcher.Constraint('Symmetric',     lastID + 1,2, lastID + 5,2, lastID + 8,1))		#Constraints[A14]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 3,2, lastID + 5,2, 2*Dist_X))			#Constraints[A15]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 8,1, lastID + 6,1))					#Constraints[A16]
		constraintList.append(Sketcher.Constraint('Horizontal',    lastID + 6))									#Constraints[A17]
		constraintList.append(Sketcher.Constraint('DistanceX',     lastID + 6,1, lastID + 6,2, Radio))			#Constraints[A18]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 8,1, lastID + 7,1))					#Constraints[A19]
		constraintList.append(Sketcher.Constraint('Parallel',      lastID + 7,   lastID + 2))						#Constraints[A20]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 7,1, lastID + 7,2, Radio))			#Constraints[A21]
		constraintList.append(Sketcher.Constraint('Angle',         lastID + 6,1, lastID + 7,1, Angulo))			#Constraints[A22]
		constraintList.append(Sketcher.Constraint('DistanceX',     lastID + 8,1, Pt1.x))							#Constraints[A23]
		constraintList.append(Sketcher.Constraint('DistanceY',     lastID + 8,1, Pt1.y))							#Constraints[A24]
	
	if Tipo == 'B':
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 10,1, lastID + 1,2))					#Constraints[B2]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 10,2, lastID + 0,1))					#Constraints[B3]
		constraintList.append(Sketcher.Constraint('PointOnObject', lastID + 0,3,  lastID + 10))					#Constraints[B4]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 6,1,  lastID + 0,3))					#Constraints[B5]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 6,2,  lastID + 0,2))					#Constraints[B6]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 5,1,  lastID + 1,2))					#Constraints[B7]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 7,1,  lastID + 0,1))					#Constraints[B8]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 3,1,  lastID + 1,2))					#Constraints[B9]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 3,2,  lastID + 2,1))					#Constraints[B10]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 2,2,  lastID + 4,2))					#Constraints[B11]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 4,1,  lastID + 0,1))					#Constraints[B12]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 6,    lastID + 10))					#Constraints[B13]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 5,    lastID + 10))					#Constraints[B14]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 7,    lastID + 10))					#Constraints[B15]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 3,    lastID + 10))					#Constraints[B16]
		constraintList.append(Sketcher.Constraint('Perpendicular', lastID + 4,    lastID + 10))					#Constraints[B17]
		constraintList.append(Sketcher.Constraint('Parallel',      lastID + 10,   lastID + 2))					#Constraints[B18]
		constraintList.append(Sketcher.Constraint('Equal',         lastID + 6,    lastID + 7))					#Constraints[B19]
		constraintList.append(Sketcher.Constraint('Equal',         lastID + 6,    lastID + 5))					#Constraints[B20]
		constraintList.append(Sketcher.Constraint('Symmetric',     lastID + 5,2,  lastID + 2,2, lastID + 11,1))	#Constraints[B21]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 5,2,  lastID + 7,2, 2*Dist_X))		#Constraints[B22]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 7,2,  lastID + 2,2, Dist_Y))			#Constraints[B23]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 11,1, lastID + 8,1))					#Constraints[B24]
		constraintList.append(Sketcher.Constraint('Horizontal',    lastID + 8))									#Constraints[B25]
		constraintList.append(Sketcher.Constraint('DistanceX',     lastID + 8,1,  lastID + 8,2, Radio))			#Constraints[B26]
		constraintList.append(Sketcher.Constraint('Coincident',    lastID + 11,1, lastID + 9,1))					#Constraints[B27]
		constraintList.append(Sketcher.Constraint('Parallel',      lastID + 9,    lastID + 10))					#Constraints[B28]
		constraintList.append(Sketcher.Constraint('Distance',      lastID + 9,1,  lastID + 9,2, Radio))			#Constraints[B29]
		constraintList.append(Sketcher.Constraint('Angle',         lastID + 8,1,  lastID + 9,1, Angulo))			#Constraints[B30]
		constraintList.append(Sketcher.Constraint('DistanceX',     lastID + 11,1, Pt1.x))							#Constraints[B31]
		constraintList.append(Sketcher.Constraint('DistanceY',     lastID + 11,1, Pt1.y))							#Constraints[B32]
	
	Boceto_X.addConstraint(constraintList)
	
	del constraintList
	
	Doc.recompute
	
	
	
#! Estos son las funciones para crear Modelado 3D
def Crear_Relleno(Titulo, Etiqueta = '', Objeto_X = False, Boceto_X = False):
	
	Relleno_X = Doc.addObject('PartDesign::Pad', Titulo)
	if Objeto_X == False:
		Doc.Tip = Relleno_X
	else:
		Objeto_X.addObject(Relleno_X)
	if Etiqueta == '':
		Relleno_X.Label = Titulo
	else:
		Relleno_X.Label = Etiqueta
	
	Relleno_X.Profile = (Boceto_X, [''])
	Relleno_X.ReferenceAxis = (Boceto_X, ['N_Axis'])
	Boceto_X.Visibility = False
	
	Doc.recompute()
	return Relleno_X
	
	
	
def Crear_Hueco(Titulo, Etiqueta = '', Objeto_X = False, Boceto_X = False):
	
	Hueco_X = Doc.addObject('PartDesign::Pocket', Titulo)
	if Objeto_X == False:
		Doc.Tip = Hueco_X
	else:
		Objeto_X.addObject(Hueco_X)
	if Etiqueta == '':
		Hueco_X.Label = Titulo
	else:
		Hueco_X.Label = Etiqueta
	
	Hueco_X.Profile = (Boceto_X, [''])
	Hueco_X.ReferenceAxis = (Boceto_X, ['N_Axis'])
	Boceto_X.Visibility = False
	
	Doc.recompute()
	return Hueco_X
	
	
	
def Crear_Revolucion(Titulo, Etiqueta = '', Objeto_X = False, Boceto_X = False, Eje_X = False, Angulo = 360, Reverso = 0):
	
	Rev_X = Doc.addObject('PartDesign::Revolution', Titulo)
	if Objeto_X == False:
		Doc.Tip = Rev_X
	else:
		Objeto_X.addObject(Rev_X)
	if Etiqueta == '':
		Rev_X.Label = Titulo
	else:
		Rev_X.Label = Etiqueta
	
	Rev_X.Profile = (Boceto_X, [''])
	if Eje_X == False:
		Rev_X.ReferenceAxis = (Boceto_X, ['V_Axis'])
	else:
		Rev_X.ReferenceAxis = (Eje_X, [''])
		Eje_X.Visibility = False
	Rev_X.Angle = Angulo
	Rev_X.Reversed = Reverso
	Boceto_X.Visibility = False
	
	Doc.recompute()
	return Rev_X
	
	
	
def Crear_Agujero(Titulo, Etiqueta = '', Objeto_X = False, Boceto_X = False, Plano_X = '', Modelado_X = ''):
	
	Agujero_X = Doc.addObject('PartDesign::Hole', Titulo)
	if Objeto_X == False:
		Doc.Tip = Agujero_X
	else:
		Objeto_X.addObject(Agujero_X)
	if Etiqueta == '':
		Agujero_X.Label = Titulo
	else:
		Agujero_X.Label = Etiqueta
	
	if Boceto_X == False:
		Agujero_X.Profile = (Modelado_X, [Plano_X])
	else:
		Agujero_X.Profile = (Boceto_X, [''])
		Boceto_X.Visibility = False
	
	Doc.recompute()
	return Agujero_X
	
	
	
def Actualizar_Lista(Boceto_X, Total_Lista):
	
	for k in range(0, Total_Lista)[::-1]:
		t = len(Lista_Obj) - k - 1
		g = Total_Lista - k - 1
		if Lista_Obj[t][6] == Boceto_X.Label:
			if Lista_Obj[t][5] == 'linea':
				Pt1_temp = [round(Boceto_X.Geometry[g].StartPoint[0],8), round(Boceto_X.Geometry[g].StartPoint[1],8), round(Boceto_X.Geometry[g].StartPoint[2],8)]
				Pt2_temp = [round(Boceto_X.Geometry[g].EndPoint[0],8),   round(Boceto_X.Geometry[g].EndPoint[1],8),   round(Boceto_X.Geometry[g].EndPoint[2],8)]
				Vector3 = App.Vector(Pt2_temp) - App.Vector(Pt1_temp)
				Longitud = round(Vector3.Length, 8)
				# Longitud
				Lista_Obj[t][1] = Longitud
				# Punto inicio
				Lista_Obj[t][2] = Pt1_temp
				# Punto final
				Lista_Obj[t][3] = Pt2_temp
			if Lista_Obj[t][5] == 'arco':
				Pt1_temp = [round(Boceto_X.Geometry[g].StartPoint[0], 8), round(Boceto_X.Geometry[g].StartPoint[1], 8), round(Boceto_X.Geometry[g].StartPoint[2], 8)]
				Pt2_temp = [round(Boceto_X.Geometry[g].EndPoint[0], 8),   round(Boceto_X.Geometry[g].EndPoint[1], 8),   round(Boceto_X.Geometry[g].EndPoint[2], 8)]
				Eje_temp = [round(Boceto_X.Geometry[g].Center[0], 8),     round(Boceto_X.Geometry[g].Center[1], 8),     round(Boceto_X.Geometry[g].Center[2], 8)]
				# Radio
				Lista_Obj[t][1] = round(Boceto_X.Geometry[g].Radius, 8)
				# Punto inicio
				Lista_Obj[t][2] = Pt1_temp
				# Punto final
				Lista_Obj[t][3] = Pt2_temp
				# Centro curva
				Lista_Obj[t][4] = Eje_temp
			if Lista_Obj[t][5] == 'circulo':
				Eje_temp = [round(Boceto_X.Geometry[g].Center[0], 8), round(Boceto_X.Geometry[g].Center[1], 8), round(Boceto_X.Geometry[g].Center[2], 8)]
				# Radio
				Lista_Obj[t][1] = round(Boceto_X.Geometry[g].Radius, 8)
				# Centro curva
				Lista_Obj[t][4] = Eje_temp
			if Lista_Obj[t][5] == 'punto':
				Pt1_temp = [round(Boceto_X.Geometry[g].X, 8), round(Boceto_X.Geometry[g].Y, 8), round(Boceto_X.Geometry[g].Z, 8)]
				# Punto inicio
				Lista_Obj[t][2] = Pt1_temp
	
	
	
#! crear Bastidor 3D
def Crear_Bastidor_3D():
	
	### iniciar la orden PartDesign_Sketch
	global Boceto_Base
	# Crear_Boceto(Titulo, Etiqueta = '', Objeto_X = False, Plano_X = '', Modelado_X = '', Mapa_X = 'FlatFace'):
	Boceto_Base = Crear_Boceto('Sketch_Base_B001', 'B_Base_B001', Cuerpo_B1, 'XZ_Plane')
	
	# creamos la lista de puntos por cada linea
	geoList = []
	# [Punto inicial, Punto final]
	geoList.append([App.Vector(-278, 19, 0), App.Vector(-151, 19, 0)])		#Object[0]
	geoList.append([App.Vector(-146, 17, 0), App.Vector(-131,  2, 0)])		#Object[1]
	geoList.append([App.Vector(-127,  0, 0), App.Vector( 127,  0, 0)])		#Object[2]
	geoList.append([App.Vector( 131,  2, 0), App.Vector( 146, 17, 0)])		#Object[3]
	geoList.append([App.Vector( 151, 19, 0), App.Vector( 278, 19, 0)])		#Object[4]
	
	for NewLinea in geoList:
		# Crear_Linea(Pt1, Pt2, Boceto_X, Guia = False):
		Crear_Linea(NewLinea[0], NewLinea[1], Boceto_Base)
	
	del geoList
	
	# creamos la lista de puntos por cada arco
	geoList = []
	# [centro curva, Eje, Radio, Angulo inicial, Angulo final]
	geoList.append([App.Vector(-151, 12, 0), App.Vector(0, 0, 1), 6.35, math.radians( 45), math.radians( 90)])	#Object[5]
	geoList.append([App.Vector(-127,  6, 0), App.Vector(0, 0, 1), 6.35, math.radians(225), math.radians(270)])	#Object[6]
	geoList.append([App.Vector( 127,  6, 0), App.Vector(0, 0, 1), 6.35, math.radians(270), math.radians(315)])	#Object[7]
	geoList.append([App.Vector( 151, 12, 0), App.Vector(0, 0, 1), 6.35, math.radians( 90), math.radians(135)])	#Object[8]
	
	for NewArco in geoList:
		# Crear_Arco(Pt1, Eje, Radio, Boceto_X, Ang_Ini, Ang_Fin, Guia = False):
		Crear_Arco(NewArco[0], NewArco[1], NewArco[2], Boceto_Base, NewArco[3], NewArco[4])
	
	del geoList
	
	# creamos la lista de restricciones
	constraintList = []
	constraintList.append(Sketcher.Constraint('Tangent',    0,2,5,2))					#Constraints[0]
	constraintList.append(Sketcher.Constraint('Tangent',    1,1,5,1))					#Constraints[1]
	constraintList.append(Sketcher.Constraint('Tangent',    1,2,6,1))					#Constraints[2]
	constraintList.append(Sketcher.Constraint('Tangent',    2,1,6,2))					#Constraints[3]
	constraintList.append(Sketcher.Constraint('Tangent',    2,2,7,1))					#Constraints[4]
	constraintList.append(Sketcher.Constraint('Tangent',    3,1,7,2))					#Constraints[5]
	constraintList.append(Sketcher.Constraint('Tangent',    3,2,8,2))					#Constraints[6]
	constraintList.append(Sketcher.Constraint('Tangent',    4,1,8,1))					#Constraints[7]
	constraintList.append(Sketcher.Constraint('Horizontal', 0))							#Constraints[8]
	constraintList.append(Sketcher.Constraint('Horizontal', 2))							#Constraints[9]
	constraintList.append(Sketcher.Constraint('Horizontal', 4))							#Constraints[10]
	constraintList.append(Sketcher.Constraint('Symmetric',  2,1,2,2,-1,1))				#Constraints[11]
	constraintList.append(Sketcher.Constraint('Symmetric',  0,1,4,2,-2))					#Constraints[12]
	constraintList.append(Sketcher.Constraint('DistanceX',  2,1,2,2,241.0))				#Constraints[13]
	constraintList.append(Sketcher.Constraint('Radius',     5,6.35))						#Constraints[14]
	constraintList.append(Sketcher.Constraint('Radius',     6,6.35))						#Constraints[15]
	constraintList.append(Sketcher.Constraint('Radius',     7,6.35))						#Constraints[16]
	constraintList.append(Sketcher.Constraint('Radius',     8,6.35))						#Constraints[17]
	constraintList.append(Sketcher.Constraint('Angle',      0,2,1,1,math.radians(135)))	#Constraints[18]
	constraintList.append(Sketcher.Constraint('Angle',      3,2,4,1,math.radians(135)))	#Constraints[19]
	constraintList.append(Sketcher.Constraint('DistanceY',  2,1,0,1,19.0))				#Constraints[20]
	constraintList.append(Sketcher.Constraint('DistanceX',  0,1,4,2,508.0))				#Constraints[21]
	
	Boceto_Base.addConstraint(constraintList)
	Boceto_Base.setExpression('Constraints[20]', u'' + Variable_B1.Name + '.Alto')
	Boceto_Base.setExpression('Constraints[21]', u'' + Variable_B1.Name + '.Largo')
	
	del constraintList
	
	# creamos la lista de puntos por cada linea
	geoList = []
	# [Punto inicial, Punto final]
	geoList.append([App.Vector(-247, 19, 0), App.Vector(-247, 16, 0)])		#Object[9]
	geoList.append([App.Vector(-247, 16, 0), App.Vector(-144, 16, 0)])		#Object[10]
	geoList.append([App.Vector(-140, 14, 0), App.Vector(-128,  0, 0)])		#Object[11]
	geoList.append([App.Vector(-120, -3, 0), App.Vector( 120, -3, 0)])		#Object[12]
	geoList.append([App.Vector( 128,  0, 0), App.Vector( 140, 14, 0)])		#Object[13]
	geoList.append([App.Vector( 144, 16, 0), App.Vector( 247, 16, 0)])		#Object[14]
	geoList.append([App.Vector( 247, 16, 0), App.Vector( 247, 19, 0)])		#Object[15]
	
	for NewLinea in geoList:
		# Crear_Linea(Pt1, Pt2, Boceto_X, Guia = False):
		Crear_Linea(NewLinea[0], NewLinea[1], Boceto_Base)
	
	del geoList
	
	# creamos la lista de puntos por cada arco
	geoList = []
	# [centro curva, Eje, Radio, Angulo inicial, Angulo final]
	geoList.append([App.Vector(-144, 12, 0), App.Vector(0, 0, 1), 3.35, math.radians( 45), math.radians( 90)])	#Object[16]
	geoList.append([App.Vector(-120,  6, 0), App.Vector(0, 0, 1), 9.35, math.radians(225), math.radians(270)])	#Object[17]
	geoList.append([App.Vector( 120,  6, 0), App.Vector(0, 0, 1), 9.35, math.radians(270), math.radians(315)])	#Object[18]
	geoList.append([App.Vector( 144, 12, 0), App.Vector(0, 0, 1), 3.35, math.radians( 90), math.radians(135)])	#Object[19]
	
	for NewArco in geoList:
		# Crear_Arco(Pt1, Eje, Radio, Boceto_X, Ang_Ini, Ang_Fin, Guia = False):
		Crear_Arco(NewArco[0], NewArco[1], NewArco[2], Boceto_Base, NewArco[3], NewArco[4])
	
	del geoList
	
	# creamos la lista de restricciones
	constraintList = []
	constraintList.append(Sketcher.Constraint('Coincident', 9,1,0,1))		#Constraints[22]
	constraintList.append(Sketcher.Constraint('Coincident', 9,2,10,1))		#Constraints[23]
	constraintList.append(Sketcher.Constraint('Coincident', 5,3,16,3))		#Constraints[24]
	constraintList.append(Sketcher.Constraint('Coincident', 6,3,17,3))		#Constraints[25]
	constraintList.append(Sketcher.Constraint('Coincident', 7,3,18,3))		#Constraints[26]
	constraintList.append(Sketcher.Constraint('Coincident', 8,3,19,3))		#Constraints[27]
	constraintList.append(Sketcher.Constraint('Coincident', 15,2,4,2))		#Constraints[28]
	constraintList.append(Sketcher.Constraint('Coincident', 14,2,15,1))		#Constraints[29]
	constraintList.append(Sketcher.Constraint('Tangent',    10,2,16,2))		#Constraints[30]
	constraintList.append(Sketcher.Constraint('Tangent',    11,1,16,1))		#Constraints[31]
	constraintList.append(Sketcher.Constraint('Tangent',    11,2,17,1))		#Constraints[32]
	constraintList.append(Sketcher.Constraint('Tangent',    12,1,17,2))		#Constraints[33]
	constraintList.append(Sketcher.Constraint('Tangent',    12,2,18,1))		#Constraints[34]
	constraintList.append(Sketcher.Constraint('Tangent',    13,1,18,2))		#Constraints[35]
	constraintList.append(Sketcher.Constraint('Tangent',    13,2,19,2))		#Constraints[36]
	constraintList.append(Sketcher.Constraint('Tangent',    14,1,19,1))		#Constraints[37]
	constraintList.append(Sketcher.Constraint('Parallel',   11,1))			#Constraints[38]
	constraintList.append(Sketcher.Constraint('Parallel',   13,3))			#Constraints[39]
	constraintList.append(Sketcher.Constraint('Vertical',   9))				#Constraints[40]
	constraintList.append(Sketcher.Constraint('Horizontal', 10))				#Constraints[41]
	constraintList.append(Sketcher.Constraint('Horizontal', 12))				#Constraints[42]
	constraintList.append(Sketcher.Constraint('Horizontal', 14))				#Constraints[43]
	constraintList.append(Sketcher.Constraint('Vertical',   15))				#Constraints[44]
	constraintList.append(Sketcher.Constraint('DistanceY',  14,2,4,2,2.0))	#Constraints[45]
	
	Boceto_Base.addConstraint(constraintList)
	Boceto_Base.setExpression('Constraints[45]', u'' + Variable_B1.Name + '.Espesor')
	
	del constraintList
	
	Doc.recompute()
	
	# Actualizar_Lista(Boceto_X, Total_Lista):
	Actualizar_Lista(Boceto_Base, len(Boceto_Base.Geometry))
	
	global Relleno_Base
	# Crear_Relleno(Titulo, Etiqueta = '', Objeto_X = False, Boceto_X = False):
	Relleno_Base = Crear_Relleno('Pad_Base_B001', 'Relleno_Base_B001', Cuerpo_B1, Boceto_Base)
	Relleno_Base.setExpression('Length', u'' + Variable_B1.Name + '.Ancho')
	Relleno_Base.SideType = 2
	
	Doc.recompute()
	
	
	
#! Crear Huecos en el Bastidor
def Crear_Huecos01_3D():
	
	### iniciar la orden PartDesign_Sketch
	global Boceto_Hueco1
	# Crear_Boceto(Titulo, Etiqueta = '', Objeto_X = False, Plano_X = '', Modelado_X = '', Mapa_X = 'FlatFace'):
	Boceto_Hueco1 = Crear_Boceto('Sketch_HuecoBase1_B001', 'B_HuecoBase1_B001', Cuerpo_B1, 'Face5', Relleno_Base)
	
	# Crear_Cuadrado(Pt1, Boceto_X, Tipo = 'Borde', Dist_X = False, Dist_Y = False, Radio = False, Angulo = 0, Guia = False):
	Crear_Cuadrado(App.Vector(0, 0, 0), Boceto_Hueco1, 'Borde', 177.8, 50.8, 3)
	
	# Crear_Cuadrado(Pt1, Boceto_X, Tipo = 'Borde', Dist_X = False, Dist_Y = False, Radio = False, Angulo = 0, Guia = False):
	Crear_Cuadrado(App.Vector(177.8 / 2 + 5 + 10 / 2, 0, 0), Boceto_Hueco1, 'Borde', 10, 50.8, 3)
	
	# Crear_Cuadrado(Pt1, Boceto_X, Tipo = 'Borde', Dist_X = False, Dist_Y = False, Radio = False, Angulo = 0, Guia = False):
	Crear_Cuadrado(App.Vector(-177.8 / 2 - 5 - 10 / 2, 0, 0), Boceto_Hueco1, 'Borde', 10, 50.8, 3)
	
	Doc.recompute()
	
	# Actualizar_Lista(Boceto_X, Total_Lista):
	Actualizar_Lista(Boceto_Hueco1, len(Boceto_Hueco1.Geometry))
	
	global Hueco_Base1
	# Crear_Hueco(Titulo, Etiqueta = '', Objeto_X = False, Boceto_X = False):
	Hueco_Base1 = Crear_Hueco('Pocket_Base1_B001', 'Hueco_Base1_B001', Cuerpo_B1, Boceto_Hueco1)
	
	Doc.recompute()
	
	
	
def Crear_Huecos02_3D(LaT, AnT, AlT):
	
	### iniciar la orden PartDesign_Sketch
	global Boceto_Hueco2
	# Crear_Boceto(Titulo, Etiqueta = '', Objeto_X = False, Plano_X = '', Modelado_X = '', Mapa_X = 'FlatFace'):
	Boceto_Hueco2 = Crear_Boceto('Sketch_HuecoBase2_B001', 'B_HuecoBase2_B001', Cuerpo_B1, 'Face1', Hueco_Base1)
	
	# Crear_Ranura(Pt1, Boceto_X, Dist_X = False, Dist_Y = False, Angulo = 0, Guia = False):
	Crear_Ranura(App.Vector(-LaT / 2 + 2.5 + 12.7 / 2, -AnT / 2 + 8 + 6.35 / 2, 0), Boceto_Hueco2, 12.7, 6.35)
	
	# Crear_Cuadrado(Pt1, Boceto_X, Tipo = 'Borde', Dist_X = False, Dist_Y = False, Radio = False, Angulo = 0, Guia = False):
	Crear_Cuadrado(App.Vector(-LaT / 2 + 2.5 + 12.7 / 2, -AnT / 2 + 8 + 6.35 + 5 + 6.35 / 2, 0), Boceto_Hueco2, 'Esquina', 12.7, 6.35)
	
	# Crear_Semicirculo(Pt1, Boceto_X, Dist_X = False, Dist_Y = False, Tipo = 'A', Angulo = 0, Guia = False):
	m = 2 * 6.35 * math.sin(math.radians(45))
	n = AlT - 2 * (6.35 - 6.35 * math.cos(math.radians(45)))
	Crear_Semicirculo(App.Vector(-241 / 2 - m - n - 5,      -AnT / 2 + 26,      0), Boceto_Hueco2, 10, 12, 'B')
	Crear_Semicirculo(App.Vector(-241 / 2 - m - n - 5,       AnT / 2 - 26,      0), Boceto_Hueco2, 10, 12, 'B', math.radians(180))
	Crear_Semicirculo(App.Vector(-241 / 2 - m - n - 5 - 20, -AnT / 2 + 26 - 10, 0), Boceto_Hueco2, 10, 12, 'B', math.radians(90))
	Crear_Semicirculo(App.Vector(-241 / 2 - m - n - 5 - 20,  AnT / 2 - 26 + 10, 0), Boceto_Hueco2, 10, 12, 'B', math.radians(90))
	
	Doc.recompute()
	
	# Actualizar_Lista(Boceto_X, Total_Lista):
	Actualizar_Lista(Boceto_Hueco2, len(Boceto_Hueco2.Geometry))
	
	global Hueco_Base2
	# Crear_Hueco(Titulo, Etiqueta = '', Objeto_X = False, Boceto_X = False):
	Hueco_Base2 = Crear_Hueco('Pocket_Base2_B001', 'Hueco_Base2_B001', Cuerpo_B1, Boceto_Hueco2)
	
	Doc.recompute()
	
	# Crear_LineaRef(Titulo, Etiqueta = '', Objeto_X = False, Eje_X = '', Modelado_X = ''):
	global DL1
	global DL2
	global DL3
	global DL4
	DL1 = Crear_LineaRef('DL1_Base2_B001', 'LinRef1_Base2_B001', Cuerpo_B1, 'Edge71',  Hueco_Base2)
	DL2 = Crear_LineaRef('DL2_Base2_B001', 'LinRef2_Base2_B001', Cuerpo_B1, 'Edge59',  Hueco_Base2)
	DL3 = Crear_LineaRef('DL3_Base2_B001', 'LinRef3_Base2_B001', Cuerpo_B1, 'Edge119', Hueco_Base2)
	DL4 = Crear_LineaRef('DL4_Base2_B001', 'LinRef4_Base2_B001', Cuerpo_B1, 'Edge111', Hueco_Base2)
	DL1.AttachmentOffset = App.Placement(App.Vector(0, -1, -241 / 2 - m - n - 10), App.Rotation(0, 0, 0))
	DL2.AttachmentOffset = App.Placement(App.Vector(0, -1,  241 / 2 + m + n),      App.Rotation(0, 0, 0))
	DL3.AttachmentOffset = App.Placement(App.Vector(0, -1,  AnT / 2 - 26 + 5),     App.Rotation(0, 0, 0))
	DL4.AttachmentOffset = App.Placement(App.Vector(0, -1, -AnT / 2 + 26 - 15),    App.Rotation(0, 0, 0))
	
