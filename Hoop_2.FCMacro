	Var_E = App.Units.Quantity(Variable_B1.Espesor).Value
	Var_R = 6.35 - 6.35 * math.cos(math.radians(45))
	Var_L = ((AlT - 2 * Var_R) / math.cos(math.radians(45))) / 2
	
	# Crear_Ranura(Pt1, Boceto_X, Dist_X = False, Dist_Y = False, Angulo = 0, Guia = False):
	Crear_Ranura(App.Vector(-Var_L + 9.5 / 2 + 5, 0, 0), Boceto_Hueco4, 50.8, 9.5, math.radians(90))
	
	# Crear_Cuadrado(Pt1, Boceto_X, Tipo = 'Borde', Dist_X = False, Dist_Y = False, Radio = False, Angulo = 0, Guia = False):
	Crear_Cuadrado(App.Vector(-Var_L + 5 / 2, 0, 0), Boceto_Hueco4, 'Esquina', 31.75, 5, Angulo = math.radians(90))
	
	Doc.recompute()
	
	# Actualizar_Lista(Boceto_X, Total_Lista):
