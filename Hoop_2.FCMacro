	# Crear_Semicirculo(Pt1, Boceto_X, Dist_X = False, Dist_Y = False, Tipo = 'B', Angulo = 0, Radio_Centro = False, Guia = False, Grupo = '-'):
	Crear_Semicirculo(App.Vector(0, -9 / 2, 0), Boceto_Tab2, 9, 9, 'B', math.radians(180), 2)
	
	# Actualizar_Lista(Boceto_X):
	Actualizar_Lista(Boceto_Tab2)
	Actualizar_Lista2(Boceto_Tab2)
	
	global Tab2_Base2
	# Crear_Relleno(Titulo, Etiqueta = '', Objeto_X = False, Boceto_X = False):
	Tab2_Base2 = Crear_Relleno('Pad_Tab2_B001', 'Relleno_Tab2_B001', Cuerpo_B1, Boceto_Tab2)
	Tab2_Base2.setExpression('Length', u'' + Variable_B1.Name + '.Espesor')
	Tab2_Base2.Reversed = 1
	
	Doc.recompute()
	
	
	
