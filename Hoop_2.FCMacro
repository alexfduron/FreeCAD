	# Crear_Revolucion(Titulo, Etiqueta = '', Objeto_X = False, Boceto_X = False, Eje_X = False, Angulo = 360, Reverso = 0):
	Doblez2_Base2 = Crear_Revolucion('Rev_Hole2_B001', 'Rev_Hueco2_B001', Cuerpo_B1, Boceto_Doblez2, DL2, 90, 1)
	
	Doc.recompute()
	
	# Crear_PlanoRef(Titulo, Etiqueta = '', Objeto_X = False, Eje_X = '', Modelado_X = ''):
	global DP2
	DP2 = Crear_PlanoRef('DP2_Base2_B001', 'PlanRef2_Base2_B001', Cuerpo_B1, 'Edge273',  Doblez2_Base2)
	DP2.AttachmentOffset = App.Placement(App.Vector(0, 0, -4.5), App.Rotation(0, 90, 0))
