	Crear_Ranura(App.Vector(-Var_L + 9.5 / 2 + 5, 0, 0), Boceto_Hueco5, 50.8, 9.5, math.radians(90))
	
	# Crear_Cuadrado(Pt1, Boceto_X, Tipo = 'Borde', Dist_X = False, Dist_Y = False, Radio = False, Angulo = 0, Guia = False):
	Crear_Cuadrado(App.Vector(-Var_L + 5 / 2, 0, 0), Boceto_Hueco5, 'Esquina', 31.75, 5, Angulo = math.radians(90))
	
	Doc.recompute()
	
	# Actualizar_Lista(Boceto_X, Total_Lista):
	Actualizar_Lista(Boceto_Hueco5, len(Boceto_Hueco5.Geometry))
	
